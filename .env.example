# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# URL мини-приложения (GitHub Pages):
# WEBAPP_URL=https://YOUR_USER.github.io/FLT
# Или если всё на Amvera:
# WEBAPP_URL=https://your-app.amvera.ru

WEBAPP_URL=https://your-app.amvera.ru

# URL бэкенда для GitHub Pages (в GitHub → Settings → Variables → API_URL)
# CORS_ORIGINS=https://YOUR_USER.github.io

# Если бот не коннектится к api.telegram.org с ПК:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

MODE=test

# Optional overrides
# GROWTH_DURATION_TEST=300
# GROWTH_DURATION_PROD=36000
# WATER_COOLDOWN_TEST=60
# WATER_COOLDOWN_PROD=86400
# WATER_TIME_REDUCTION=600
# SELF_WATER_COOLDOWN_TEST=10
# SELF_WATER_COOLDOWN_PROD=86400
# SELF_WATER_REDUCTION_PERCENT_TEST=90
# SELF_WATER_REDUCTION_PERCENT_PROD=15
# NEW_USER_BONUS=100
# REFERRER_BONUS=50
# WATER_BONUS=5
