# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
WEBAPP_URL=http://127.0.0.1:8000

# Тестовый режим (короткие таймеры). На Amvera для релиза: MODE=prod
MODE=test
ADMIN_TELEGRAM_ID=5143241640

# Локальный Postgres (docker compose up -d postgres или scripts/start_db.ps1)
DATABASE_URL=postgresql://garden:garden@127.0.0.1:5432/garden

# На Amvera без Postgres — оставь DATABASE_URL пустым, будет SQLite в /data/garden.db
# DATABASE_URL=

# Одноразовый полный сброс БД при старте:
# RESET_DB=true

# DEV_MODE=true
# DEV_USER_ID=1001
