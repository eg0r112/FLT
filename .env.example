# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
WEBAPP_URL=https://your-app.amvera.ru

MODE=prod
ADMIN_TELEGRAM_ID=5143241640

# PostgreSQL (создай сервис PostgreSQL на Amvera и вставь URL):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Одноразовый полный сброс БД при старте:
# RESET_DB=true

# Масштабирование:
# RUN_MODE=both
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...

# Тайминги (секунды) — по умолчанию уже настроены:
# GROWTH_DURATION_PROD=18000      # 5 ч
# WATER_TIME_REDUCTION=3600       # −1 ч за полив
# SELF_WATER_COOLDOWN_PROD=18000  # свой полив раз в 5 ч
# WATER_COOLDOWN_PROD=86400       # полив друга раз в сутки на грядку
